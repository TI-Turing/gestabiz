{
  "buildCommand": "npm run generate-sitemap && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --ignore-scripts",
  "rewrites": [
    {
      "source": "/negocio/:slug",
      "destination": "/api/negocio/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/app/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "https://dkancockzvcqorqbwtyh.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRrYW5jb2NrenZjcW9ycWJ3dHloIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTY4MTM5MDQsImV4cCI6MjA3MjM4OTkwNH0.tUZY4n2QLQCM3mLn4MrR-mN4fMhJkkHizy993SKx-o4",
    "VITE_DEMO_MODE": "false",
    "VITE_SITE_URL": "https://gestabiz.com"
  }
}
