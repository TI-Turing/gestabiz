# ============================================
# AMBIENTE: DEV / STAGING
# ============================================
# Copia este archivo a la raíz del proyecto como: .env.staging
# cp environments/dev/.env.template .env.staging
#
# Este ambiente usa el proyecto Supabase DEV (separado de producción).
# Las GitHub Actions lo inyectan automáticamente via Secrets del repositorio.
# Para desarrollo local apuntando a dev: usa este archivo como .env.staging
# y corre: npm run dev:staging
# ============================================

# --- SUPABASE DEV ---
# Obtén estos valores del proyecto Supabase DEV en: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-dev-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key-here

# --- APP ---
VITE_APP_URL=https://dev.gestabiz.com
VITE_APP_NAME=Gestabiz [DEV]
VITE_SITE_URL=https://dev.gestabiz.com
VITE_DEMO_MODE=false

# --- GOOGLE OAUTH ---
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# --- PAGOS (usa sandbox/test keys en dev) ---
VITE_PAYMENT_GATEWAY=mercadopago
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-your-sandbox-public-key

# --- SOPORTE ---
VITE_SUPPORT_EMAIL=dev@gestabiz.com

# --- SENTRY (entorno staging) ---
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_APP_VERSION=0.0.0-dev
VITE_SENTRY_SAMPLE_RATE=1.0

# --- GOOGLE ANALYTICS (ID separado para dev, o desactivar) ---
# VITE_GA_MEASUREMENT_ID=G-DEV-XXXXXXXXXX
VITE_GA_FORCE_IN_DEV=false
